{
  "name": "@volatil/rule-engine-trading-testkit",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Integration test harness for @volatil/rule-engine-trading against a simulated broker",
  "exports": {
    ".": {
      "import": "./src/public-api.ts",
      "types": "./src/public-api.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@volatil/rule-engine-trading": "workspace:*",
    "rule-engine-monorepo": "github:VolatilCapital/rule-engine-monorepo#b30d7575",
    "decimal.js": "^10.6.0"
  },
  "peerDependencies": {
    "@volatil/simulated-platform": "*"
  },
  "devDependencies": {
    "@volatil/simulated-platform": "link:../../../simulated-platform-monorepo/packages/simulated-platform",
    "@types/node": "^22.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
